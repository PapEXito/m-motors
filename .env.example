# Copier ce fichier en .env et renseigner les valeurs avant de lancer en production.
# En local : seule DATABASE_URL est necessaire si vous voulez tester avec PostgreSQL.

# Cle secrete Django (50+ caracteres, unique par environnement)
# Generer : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=votre-cle-secrete-50-caracteres-minimum

# Desactiver le mode debug en production
DEBUG=False

# Hotes autorises (separes par des virgules)
ALLOWED_HOSTS=.railway.app,.votre-domaine.com

# Origines CSRF de confiance (Railway impose HTTPS)
CSRF_TRUSTED_ORIGINS=https://*.railway.app

# Base de donnees PostgreSQL (OBLIGATOIRE en production)
# Railway injecte automatiquement DATABASE_URL quand vous ajoutez le plugin PostgreSQL.
# Format : postgresql://user:password@host:5432/nomdb
DATABASE_URL=postgresql://user:password@localhost:5432/mmotors

# --- Alerting / monitoring ---------------------------------------------------
# Destinataires des mails ERROR (handler mail_admins).
# Format : Nom1:mail1@x.fr,Nom2:mail2@x.fr
DJANGO_ADMINS=Lorenzo:garsiglialorenzo@gmail.com

# SMTP pour l'envoi des alertes (laisser vide pour console backend en dev)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=alerts@m-motors.local
EMAIL_HOST_PASSWORD=mot-de-passe-application
EMAIL_USE_TLS=True
SERVER_EMAIL=alerts@m-motors.local

# Sentry (error tracking) — optionnel. Laisser vide pour desactiver.
# Cree un projet sur https://sentry.io et copie la DSN.
SENTRY_DSN=
SENTRY_TRACES_RATE=0.1
SENTRY_ENV=production
